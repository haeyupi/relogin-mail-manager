SUB2API_PRIORITY=50

# OpenAI/Codex OAuth settings.
AUTH_BASE_URL=https://auth.openai.com
CODEX_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
PREFER_ONE_TIME_CODE=true

# Timeouts
EMAIL_POLL=120
POLL_INTERVAL=3
SENTINEL_TOKEN=90
MAIL_READER_REQUEST=30
